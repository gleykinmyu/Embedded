{
    // Скопируйте в settings.json (локально, не коммитится):
    //   Windows:  copy .vscode\settings.json.example .vscode\settings.json
    //   macOS:    cp .vscode/settings.json.example .vscode/settings.json
    //
    // Затем добавьте ОДИН вариант clangd.path (или оставьте без ключа, если clangd в PATH):
    //   Windows (portable после tools/bootstrap-clangd.ps1):
    //     "clangd.path": "${workspaceFolder}/tools/clangd-portable/clangd_22.1.0/bin/clangd.exe",
    //   macOS/Linux (обёртка):
    //     "clangd.path": "${workspaceFolder}/tools/clangd-select.sh",
    //   Windows через .cmd (нужен флаг для argv): вместе с
    //     "clangd.useScriptAsExecutable": true,
    //     "clangd.path": "${workspaceFolder}/tools/clangd-select.cmd",
    //
    // clangd.arguments + .cmd на Node 20: без useScriptAsExecutable --query-driver может не доехать.
    // Cursor Tab: при проблемах с сетью — HTTP Compatibility Mode в настройках Cursor.
    "C_Cpp.intelliSenseEngine": "disabled",
    "C_Cpp.autocomplete": "disabled",
    "C_Cpp.errorSquiggles": "disabled",
    "C_Cpp.formatting": "disabled",
    "C_Cpp.default.configurationProvider": "",
    "editor.inlineSuggest.enabled": true,
    "cursor.completions.enabled": true,
    "editor.semanticHighlighting.enabled": true,
    "editor.inlayHints.enabled": "onUnlessPressed",
    "[c]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": false
        },
        "editor.suggestOnTriggerCharacters": true,
        "editor.parameterHints.enabled": true,
        "editor.inlineSuggest.enabled": true
    },
    "[cpp]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": false
        },
        "editor.suggestOnTriggerCharacters": true,
        "editor.parameterHints.enabled": true,
        "editor.inlineSuggest.enabled": true
    },
    "clangd.arguments": [
        "--query-driver=**/arm-none-eabi-g++*",
        "--query-driver=**/arm-none-eabi-gcc*",
        "--query-driver=**/arm-none-eabi-g++.exe",
        "--query-driver=**/arm-none-eabi-gcc.exe"
    ],
    "workbench.sideBar.location": "left",
    "workbench.activityBar.location": "default",
    "workbench.activityBar.orientation": "vertical"
}
